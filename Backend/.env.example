# Backend Environment Variables
# Copy to .env and fill values

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/brindra?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-separate-refresh-secret-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
PORT=5000
NODE_ENV=production

# Optional
FRONTEND_URL=https://your-frontend.netlify.app
